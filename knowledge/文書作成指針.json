  "cards": [
    {
      "id": "card-0001",
      "scope": "共通",
      "body": "子ども・保護者の個人名は書類に書かない（仮名・イニシャル・属性で表す）。",
      "rationale": "個人情報保護（§14）。生成書類に実名を残さない。",
      "source": "seed:初版",
      "status": "active",
      "supersedes": null,
      "superseded_by": null,
      "created_at": "2026-06-21T00:00:00",
      "updated_at": "2026-06-21T00:00:00"
    },
    {
      "id": "card-0002",
      "scope": "共通",
      "body": "断定的な発達評価を避け、観察事実と解釈を分けて書く。",
      "rationale": "保護者向け表現の適切さ・保育所保育指針との整合。",
      "source": "seed:初版",
      "status": "active",
      "supersedes": null,
      "superseded_by": null,
      "created_at": "2026-06-21T00:00:00",
      "updated_at": "2026-06-21T00:00:00"
    },
    {
      "id": "card-0003",
      "scope": "月案",
      "body": "記述は5領域（乳児は3つの視点）と10の姿に紐づける。",
      "rationale": "年齢分岐（0–2＝3つの視点／3–5＝5領域）と10の姿マッピング（§10）。",
      "source": "seed:初版",
      "status": "active",
      "supersedes": null,
      "superseded_by": null,
      "created_at": "2026-06-21T00:00:00",
      "updated_at": "2026-06-21T00:00:00"
    },
    {
      "id": "card-0004",
      "scope": "保育経過記録",
      "body": "保護者に開示され得る書類なので、断定的・否定的な評価（「〜できない」「発達が遅い」等）は避け、肯定的にリフレーミングして具体的なエピソードで書く。",
      "rationale": "保育経過記録は開示請求で開示され得る公式記録（§19）。課題も「時には〜することもあるが…」と柔らかく、子どもの主体と保育者の援助として書く。",
      "source": "seed:初版",
      "status": "active",
      "supersedes": null,
      "superseded_by": null,
      "created_at": "2026-07-05T00:00:00",
      "updated_at": "2026-07-05T00:00:00"
    },
    {
      "id": "card-0005",
      "scope": "保育要録",
      "body": "小学校の先生が読み取れるよう、成長の著しい点を5領域と10の姿の視点で具体的なエピソードとともに書く。抽象的な評価で終えず「必要に応じてさまざまな表現材料を提供し、本児のイメージがうまく表現できるよう援助した」のように、子どもの姿と保育者の援助をセットで書く。",
      "rationale": "保育要録は小学校への引き継ぎが目的（§19・L4）。就学先の先生に具体的に何をしたかが伝わる表現にする。開示前提は保育経過記録と共通（card-0004）。",
      "source": "seed:初版",
      "status": "active",
      "supersedes": null,
      "superseded_by": null,
      "created_at": "2026-07-05T00:00:00",
      "updated_at": "2026-07-05T00:00:00"
    },
    {
      "id": "card-0006",
      "scope": "月案",
      "body": "個別月案の作成では、対象児の前月の保育日誌を参照する。クラス月案の作成では、クラスの在籍児名簿、クラス児童のこれまでの保育経過記録すべて、それまでのクラス月案すべて、保育経過記録に未反映の期間の日誌を参照する。",
      "rationale": "依存モデル 2026-07。個別月案とクラス月案は同じ「月案」scopeを共有するため、両方の参照方針を1枚に明示する。",
      "source": "seed:初版",
      "status": "active",
      "supersedes": null,
      "superseded_by": null,
      "created_at": "2026-07-12T00:00:00",
      "updated_at": "2026-07-12T00:00:00"
    },
    {
      "id": "card-0007",
      "scope": "保育経過記録",
      "body": "保育経過記録の作成では、対象期間の保育日誌と、前回までの保育経過記録すべてを参照する。",
      "rationale": "依存モデル 2026-07",
      "source": "seed:初版",
