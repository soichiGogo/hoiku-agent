# GCP / Vertex AI 設定（cp .env.example .env して記入。.env はコミットしない）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# RAG corpus / Memory Bank のリージョン（これらは regional 専用＝global 不可）。
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI を使う（ADK が Gemini を Vertex 経由で呼ぶ）
GOOGLE_GENAI_USE_VERTEXAI=true

# 使用モデル（最新の Gemini モデルIDに合わせる。Claude を Model Garden 経由で使う場合はここを差し替え）
GEMINI_MODEL=gemini-3.5-flash
# 生成モデルだけを固定する location。Gemini 3.x は Vertex の global エンドポイント専用なので、
# RAG/Memory（regional）とは別に global に振る（models.build_model が GOOGLE_CLOUD_LOCATION と分離）。
# regional 専用モデル（例 gemini-2.5-pro）に戻すなら空にする＝GOOGLE_CLOUD_LOCATION を使う。
MODEL_LOCATION=global

# 静的ナレッジ＝Vertex RAG corpus（保育所保育指針・10の姿）。作成後に corpus 名を記入
RAG_CORPUS=

# Agent Engine Memory Bank の ID（子ども別長期メモリ。recall_child_history が使う）。
# 用途は Memory Bank に限定（Runtime / 評価とは別物＝設計コンテキスト §9）。作成後に記入
AGENT_ENGINE_ID=

# ストレージ DB（Cloud SQL PostgreSQL）＝書類アーカイブ（record_store）と育つ指針カードブック
# （policy_store・Phase 2 で GCS から統合）が共有する。
# 例) ローカル: postgresql+psycopg://hoiku:hoiku@localhost:5432/hoiku
#     Cloud Run: postgresql+psycopg://USER:PASS@/hoiku?host=/cloudsql/PROJECT:REGION:INSTANCE
# 空なら降格＝アーカイブは永続化しない・指針はローカルファイル（Cloud Run では揮発）。
# スキーマ適用は `uv run alembic upgrade head`。
DATABASE_URL=

# 配布デモUI（/app/）の簡易共有パスコード。設定すると LLM を回す口（/run・/run_sse・
# /run_live・/api/improve）が要パスコードになり、無認証の公開リンクでの Gemini 課金を防ぐ。
# 空なら無効＝ローカル開放。審査員配布リンクでは設定推奨。
DEMO_PASSCODE=

# IAP for Cloud Run（Phase 3 認証）の JWT audience。IAP を有効化したサービスでのみ設定する
# （Cloud Console の IAP 設定 → 対象リソースの「JWT オーディエンスコードの取得」の値）。
# 設定すると x-goog-iap-jwt-assertion を署名検証し、検証済み Google アカウント email を
# 承認・編集の証跡（actor）に使う。空なら完全降格＝ヘッダを信用しない（従来の自己申告）。
IAP_AUDIENCE=

# ログ整形（任意）。既定は Cloud Run（K_SERVICE 有）で JSON・ローカルで人が読めるテキスト。
# 明示するなら LOG_FORMAT=json|text、詳細度は LOG_LEVEL=DEBUG|INFO|WARNING|ERROR（既定 INFO）。
LOG_FORMAT=
LOG_LEVEL=

# Cloud Trace へのスパンエクスポート（可観測性・任意）。true にすると agent 実行・LLM・ツール呼び出しの
# トレースが GOOGLE_CLOUD_PROJECT の Cloud Trace へ送られる（書込権限＝ADC か実行SAの
# roles/cloudtrace.agent が前提）。空/false なら送らない＝ローカル既定。本番は deploy.yml が注入する。
TRACE_TO_CLOUD=
