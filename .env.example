# GCP / Vertex AI 設定（cp .env.example .env して記入。.env はコミットしない）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI を使う（ADK が Gemini を Vertex 経由で呼ぶ）
GOOGLE_GENAI_USE_VERTEXAI=true

# 使用モデル（最新の Gemini モデルIDに合わせる。Claude を Model Garden 経由で使う場合はここを差し替え）
GEMINI_MODEL=gemini-2.5-pro

# Vertex RAG Engine（B独自DB：保育所保育指針・10の姿）。作成後に corpus 名を記入
RAG_CORPUS=

# Agent Engine（長期メモリ / 評価）。デプロイ後に記入
AGENT_ENGINE_ID=
