# GCP / Vertex AI 設定（cp .env.example .env して記入。.env はコミットしない）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# RAG corpus / Memory Bank のリージョン（これらは regional 専用＝global 不可）。
GOOGLE_CLOUD_LOCATION=us-central1

# Vertex AI を使う（ADK が Gemini を Vertex 経由で呼ぶ）
GOOGLE_GENAI_USE_VERTEXAI=true

# 使用モデル（最新の Gemini モデルIDに合わせる。Claude を Model Garden 経由で使う場合はここを差し替え）
GEMINI_MODEL=gemini-3.5-flash
# 生成モデルだけを固定する location。Gemini 3.x は Vertex の global エンドポイント専用なので、
# RAG/Memory（regional）とは別に global に振る（models.build_model が GOOGLE_CLOUD_LOCATION と分離）。
# regional 専用モデル（例 gemini-2.5-pro）に戻すなら空にする＝GOOGLE_CLOUD_LOCATION を使う。
MODEL_LOCATION=global

# 静的ナレッジ＝Vertex RAG corpus（保育所保育指針・10の姿）。作成後に corpus 名を記入
RAG_CORPUS=

# Agent Engine Memory Bank の ID（子ども別長期メモリ。recall_child_history が使う）。
# 用途は Memory Bank に限定（Runtime / 評価とは別物＝設計コンテキスト §9）。作成後に記入
AGENT_ENGINE_ID=

# 配布デモUI（/app/）の簡易共有パスコード。設定すると LLM を回す口（/run・/run_sse・
# /run_live・/api/improve）が要パスコードになり、無認証の公開リンクでの Gemini 課金を防ぐ。
# 空なら無効＝ローカル開放。審査員配布リンクでは設定推奨。
DEMO_PASSCODE=
